# Cloudflare Pages headers
# HTML: always check for freshness
# JS/CSS: always revalidate — no aggressive caching (these change per-deploy)
# Images: cache long-term (rarely change)
# Data: short TTL for live market data

/*
  Cache-Control: public, max-age=0, must-revalidate
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://morning-briefing-chat.rcobwq7u.workers.dev; style-src 'self' 'unsafe-inline'; img-src 'self' data:

/assets/js/*
  Cache-Control: public, no-cache, must-revalidate

/assets/css/*
  Cache-Control: public, no-cache, must-revalidate

/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=3600
