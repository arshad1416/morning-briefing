/* Cloudflare Pages headers */
/* Security headers + caching for static assets */

/data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=3600

/assets/*
  Cache-Control: public, max-age=86400, immutable

/* Allow chat worker to be called from this domain */
/content-security-policy: default-src 'self'; connect-src 'self' https://chat-api.yourdomain.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:
